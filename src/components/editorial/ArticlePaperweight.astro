---
import type { PaperweightImage } from '../../lib/paperweight';

type Props = {
  items: PaperweightImage[];
  startIndex: number;
  width?: number;
};

const { items, startIndex, width = 64 } = Astro.props;
const uid = `pw-${startIndex}-${items.length}`;
const safeStartIndex = items.length > 0 ? ((startIndex % items.length) + items.length) % items.length : 0;
const initial = items[safeStartIndex] ?? items[0];
---

{
  initial && items.length > 0 && (
    <div
      class="article-paperweight hidden lg:block"
      data-paperweight
      data-start-index={safeStartIndex}
      data-items={JSON.stringify(items)}
      data-expand-label="Expand paperweight"
      data-collapse-label="Collapse paperweight"
    >
      <button
        type="button"
        class="article-paperweight__chip"
        aria-expanded="false"
        aria-controls={`${uid}-preview`}
        aria-label={`Expand ${initial.title}`}
      >
        <img
          src={initial.src}
          alt=""
          width={width}
          height={width}
          class="article-paperweight__thumb"
          loading="lazy"
          decoding="async"
          data-paperweight-thumb
        />
      </button>

      <div
        id={`${uid}-preview`}
        class="article-paperweight__preview"
        hidden
        role="dialog"
        aria-modal="true"
        aria-label={initial.title}
      >
        <button type="button" class="article-paperweight__backdrop" aria-label="Close expanded image">
        </button>
        <figure class="article-paperweight__figure">
          <button type="button" class="article-paperweight__close" aria-label="Close expanded image">
            <span aria-hidden="true">×</span>
          </button>
          <img
            src={initial.src}
            alt={initial.alt}
            class="article-paperweight__full"
            width={640}
            height={640}
            data-paperweight-full
          />
          <figcaption class="article-paperweight__caption">
            <p class="article-paperweight__title" data-paperweight-title>{initial.title}</p>
            <p class="article-paperweight__fact" data-paperweight-fact>{initial.funFact}</p>
            {
              items.length > 1 && (
                <button type="button" class="article-paperweight__next" data-paperweight-next>
                  Next paperweight
                </button>
              )
            }
          </figcaption>
        </figure>
      </div>
    </div>
  )
}

<script>
  type PaperweightItem = {
    src: string;
    title: string;
    alt: string;
    funFact: string;
  };

  function parseItems(root: HTMLElement): PaperweightItem[] {
    try {
      const parsed = JSON.parse(root.dataset.items ?? '[]');
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function bindPaperweight(root: HTMLElement) {
    const items = parseItems(root);
    if (items.length === 0) return;

    const chip = root.querySelector('.article-paperweight__chip');
    const preview = root.querySelector('.article-paperweight__preview');
    const backdrop = root.querySelector('.article-paperweight__backdrop');
    const closeBtn = root.querySelector('.article-paperweight__close');
    const nextBtn = root.querySelector('[data-paperweight-next]');
    const thumb = root.querySelector('[data-paperweight-thumb]');
    const full = root.querySelector('[data-paperweight-full]');
    const title = root.querySelector('[data-paperweight-title]');
    const fact = root.querySelector('[data-paperweight-fact]');

    if (
      !(chip instanceof HTMLButtonElement) ||
      !(preview instanceof HTMLElement) ||
      !(backdrop instanceof HTMLButtonElement) ||
      !(closeBtn instanceof HTMLButtonElement) ||
      !(thumb instanceof HTMLImageElement) ||
      !(full instanceof HTMLImageElement) ||
      !(title instanceof HTMLElement) ||
      !(fact instanceof HTMLElement)
    ) {
      return;
    }

    let index = Number.parseInt(root.dataset.startIndex ?? '0', 10);
    if (Number.isNaN(index)) index = 0;
    index = ((index % items.length) + items.length) % items.length;

    const render = () => {
      const item = items[index];
      thumb.src = item.src;
      full.src = item.src;
      full.alt = item.alt;
      title.textContent = item.title;
      fact.textContent = item.funFact;
      preview.setAttribute('aria-label', item.title);
      chip.setAttribute('aria-label', root.classList.contains('is-expanded')
        ? `Collapse ${item.title}`
        : `Expand ${item.title}`);
    };

    const open = () => {
      preview.hidden = false;
      requestAnimationFrame(() => root.classList.add('is-expanded'));
      chip.setAttribute('aria-expanded', 'true');
      chip.setAttribute('aria-label', `Collapse ${items[index].title}`);
      document.body.classList.add('paperweight-open');
    };

    const close = () => {
      root.classList.remove('is-expanded');
      chip.setAttribute('aria-expanded', 'false');
      chip.setAttribute('aria-label', `Expand ${items[index].title}`);
      document.body.classList.remove('paperweight-open');

      window.setTimeout(() => {
        if (!root.classList.contains('is-expanded')) preview.hidden = true;
      }, 350);
    };

    const toggle = () => {
      if (root.classList.contains('is-expanded')) close();
      else open();
    };

    const next = () => {
      index = (index + 1) % items.length;
      render();
    };

    render();

    chip.addEventListener('click', toggle);
    backdrop.addEventListener('click', close);
    closeBtn.addEventListener('click', close);
    nextBtn?.addEventListener('click', (event) => {
      event.stopPropagation();
      next();
    });

    root.addEventListener('keydown', (event) => {
      if (!root.classList.contains('is-expanded')) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        close();
        chip.focus();
      }

      if (event.key === 'ArrowRight' && items.length > 1) {
        event.preventDefault();
        next();
      }
    });
  }

  function initPaperweights() {
    document.querySelectorAll('[data-paperweight]').forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.paperweightBound === 'true') return;
      root.dataset.paperweightBound = 'true';
      bindPaperweight(root);
    });
  }

  initPaperweights();
  document.addEventListener('astro:page-load', initPaperweights);
  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll('[data-paperweight-bound]').forEach((root) => {
      root.removeAttribute('data-paperweight-bound');
    });
  });
</script>

<style>
  .article-paperweight {
    position: sticky;
    top: clamp(14rem, 38vh, 22rem);
    z-index: 2;
    float: right;
    clear: right;
    width: 0;
    height: 0;
    margin-right: -0.5rem;
  }

  .article-paperweight__chip {
    pointer-events: auto;
    position: absolute;
    right: 0;
    top: 0;
    translate: 42% 0;
    padding: 0.625rem;
    border: 0.5px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-surface) 78%, transparent);
    box-shadow:
      0 0 0 0.5px color-mix(in srgb, var(--color-border) 35%, transparent),
      0 8px 24px color-mix(in srgb, var(--color-ink) 8%, transparent),
      0 2px 6px color-mix(in srgb, var(--color-ink) 4%, transparent);
    backdrop-filter: blur(12px) saturate(1.2);
    -webkit-backdrop-filter: blur(12px) saturate(1.2);
    rotate: 4deg;
    cursor: zoom-in;
    transition:
      rotate 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
      translate 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
      box-shadow 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .article-paperweight__chip:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-accent) 65%, transparent);
    outline-offset: 3px;
  }

  .article-paperweight__thumb {
    display: block;
    width: auto;
    height: auto;
    max-width: 4rem;
    opacity: 0.9;
    filter: saturate(0.94);
    user-select: none;
    pointer-events: none;
  }

  .article-paperweight__preview {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 2.5rem);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.32s cubic-bezier(0.25, 0.1, 0.25, 1),
      visibility 0.32s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .article-paperweight__preview[hidden] {
    display: none;
  }

  .article-paperweight.is-expanded .article-paperweight__preview {
    display: flex;
    opacity: 1;
    visibility: visible;
  }

  .article-paperweight__backdrop {
    position: absolute;
    inset: 0;
    border: none;
    background: color-mix(in srgb, var(--color-ink) 24%, transparent);
    backdrop-filter: blur(14px) saturate(1.15);
    -webkit-backdrop-filter: blur(14px) saturate(1.15);
    cursor: zoom-out;
  }

  .article-paperweight__figure {
    position: relative;
    z-index: 1;
    margin: 0;
    max-width: min(92vw, 24rem);
    padding: 0.75rem;
    border: 0.5px solid color-mix(in srgb, var(--color-border) 75%, transparent);
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    box-shadow:
      0 0 0 0.5px color-mix(in srgb, var(--color-border) 35%, transparent),
      0 24px 64px color-mix(in srgb, var(--color-ink) 18%, transparent);
    transform: scale(0.88);
    transition: transform 0.36s cubic-bezier(0.25, 0.1, 0.25, 1);
    cursor: default;
  }

  .article-paperweight.is-expanded .article-paperweight__figure {
    transform: scale(1);
  }

  .article-paperweight__full {
    display: block;
    width: 100%;
    height: auto;
    max-height: min(70vh, 28rem);
    object-fit: contain;
    border-radius: 0.75rem;
    user-select: none;
  }

  .article-paperweight__caption {
    margin-top: 0.875rem;
    padding-top: 0.875rem;
    border-top: 0.5px solid color-mix(in srgb, var(--color-border) 65%, transparent);
    text-align: left;
  }

  .article-paperweight__title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  .article-paperweight__fact {
    margin: 0.5rem 0 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-muted);
  }

  .article-paperweight__fact::before {
    content: 'Fun fact';
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-muted) 85%, var(--color-accent));
  }

  .article-paperweight__next {
    margin-top: 0.875rem;
    border: 0.5px solid color-mix(in srgb, var(--color-border) 75%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    padding: 0.45rem 0.875rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-ink);
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .article-paperweight__next:hover {
    background: color-mix(in srgb, var(--color-ink) 6%, transparent);
    border-color: color-mix(in srgb, var(--color-border) 90%, var(--color-accent));
  }

  .article-paperweight__next:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-accent) 65%, transparent);
    outline-offset: 2px;
  }

  .article-paperweight__close {
    position: absolute;
    top: 0.35rem;
    right: 0.35rem;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 1.75rem;
    height: 1.75rem;
    border: none;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface) 80%, transparent);
    color: var(--color-muted);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .article-paperweight__close:hover {
    background: color-mix(in srgb, var(--color-ink) 8%, transparent);
    color: var(--color-ink);
  }

  .article-paperweight__close:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-accent) 65%, transparent);
    outline-offset: 2px;
  }

  :global(body.paperweight-open) {
    overflow: hidden;
  }

  @media (hover: hover) {
    .article-paperweight__chip:hover {
      rotate: 0deg;
      translate: 38% -2px;
      box-shadow:
        0 0 0 0.5px color-mix(in srgb, var(--color-border) 35%, transparent),
        0 12px 32px color-mix(in srgb, var(--color-ink) 10%, transparent),
        0 4px 10px color-mix(in srgb, var(--color-ink) 5%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-paperweight__chip,
    .article-paperweight__preview,
    .article-paperweight__figure {
      transition: none;
    }

    .article-paperweight__chip:hover {
      rotate: 4deg;
      translate: 42% 0;
    }

    .article-paperweight__figure {
      transform: none;
    }
  }
</style>
