---
import type { CollectionEntry } from 'astro:content';

type Props = {
  project: CollectionEntry<'projects'>;
};

const { project } = Astro.props;
const { title, description, tech, github, demo, image, imageFit } = project.data;
const href = `/projects/${project.id}`;
const isLogo = imageFit === 'contain';
---

<article class="project-row group border-b border-[var(--color-border)] last:border-b-0">
  <div class="flex flex-col gap-4 py-7 sm:flex-row sm:items-start sm:gap-6">
    <a
      href={href}
      class:list={[
        'media-frame media-frame--thumb block shrink-0 transition-opacity group-hover:opacity-90',
        isLogo && 'media-frame--logo',
      ]}
      tabindex="-1"
      aria-hidden="true"
    >
      {
        image ? (
          <img src={image} alt="" loading="lazy" />
        ) : (
          <div
            class="flex h-36 w-full items-center justify-center text-xs text-[var(--color-muted)] sm:h-[6.75rem] sm:w-36"
          >
            {title}
          </div>
        )
      }
    </a>

    <div class="min-w-0 flex-1 text-left">
      <h2 class="text-lg font-semibold leading-snug tracking-tight sm:text-xl">
        <a href={href} class="text-[var(--color-ink)] no-underline hover:text-[var(--color-accent)]">
          {title}
        </a>
      </h2>
      <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)] sm:text-base">
        {description}
      </p>
      {
        tech.length > 0 && (
          <ul class="mt-3 flex flex-wrap gap-1.5">
            {tech.map((t) => (
              <li class="rounded-md bg-[color-mix(in_srgb,var(--color-ink)_5%,transparent)] px-2 py-0.5 text-xs text-[var(--color-muted)]">
                {t}
              </li>
            ))}
          </ul>
        )
      }
      <div class="mt-3 flex flex-wrap gap-4 text-sm">
        <a href={href} class="font-medium text-[var(--color-accent)] no-underline hover:underline">
          Read more →
        </a>
        {
          github && (
            <a
              href={github}
              class="text-[var(--color-muted)] no-underline hover:text-[var(--color-ink)]"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          )
        }
        {
          demo && (
            <a
              href={demo}
              class="text-[var(--color-muted)] no-underline hover:text-[var(--color-ink)]"
              target="_blank"
              rel="noopener noreferrer"
            >
              Demo
            </a>
          )
        }
      </div>
    </div>
  </div>
</article>
