---
type DecorItem = {
  src: string;
  alt: string;
  position: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right' | 'inline';
  width?: number;
};

type Props = {
  hero?: string;
  heroAlt?: string;
  decor?: DecorItem[];
  accent?: string;
  paper?: string;
};

const { hero, heroAlt = '', decor = [], accent = '#1d4ed8', paper = '#f7f3eb' } = Astro.props;

const positionClasses: Record<DecorItem['position'], string> = {
  'top-left': 'top-4 left-4 md:top-8 md:left-8',
  'top-right': 'top-4 right-4 md:top-8 md:right-8',
  'bottom-left': 'bottom-4 left-4 md:bottom-8 md:left-8',
  'bottom-right': 'bottom-4 right-4 md:bottom-8 md:right-8',
  inline: 'relative mx-auto my-8',
};
---

<section
  class="relative overflow-hidden"
  style={`background: linear-gradient(180deg, ${paper} 0%, color-mix(in srgb, ${paper} 88%, white) 100%)`}
  aria-hidden={!hero && decor.length === 0}
>
  {
    hero && (
      <Fragment>
        <img
          src={hero}
          alt={heroAlt}
          class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-90"
          loading="eager"
          fetchpriority="high"
        />
        {/* Keep the text side readable while letting the fresco show on the right. */}
        <div
          class="pointer-events-none absolute inset-0"
          style={`background: linear-gradient(90deg, ${paper} 0%, color-mix(in srgb, ${paper} 80%, transparent) 30%, color-mix(in srgb, ${paper} 30%, transparent) 60%, transparent 90%)`}
          aria-hidden="true"
        />
        {/* Soft fade into the article at the bottom. */}
        <div
          class="pointer-events-none absolute inset-0"
          style={`background: linear-gradient(180deg, transparent 55%, color-mix(in srgb, ${paper} 70%, transparent) 85%, ${paper} 100%)`}
          aria-hidden="true"
        />
      </Fragment>
    )
  }

  {
    !hero && (
      <div
        class="pointer-events-none absolute top-1/2 right-[8%] h-48 w-48 -translate-y-1/2 rounded-full opacity-25 blur-3xl md:h-64 md:w-64"
        style={`background: ${accent}`}
        aria-hidden="true"
      />
    )
  }

  <div class="page-container relative z-10 flex min-h-[clamp(13rem,22vw,17rem)] flex-col justify-center py-12 md:py-16">
    <slot />
  </div>

  {
    decor.map((item) => (
      <img
        src={item.src}
        alt={item.alt}
        width={item.width ?? 140}
        class:list={[
          'pointer-events-none z-10 h-auto opacity-90',
          item.position === 'inline'
            ? 'relative mx-auto my-8 block max-w-xs'
            : `absolute hidden md:block ${positionClasses[item.position]}`,
        ]}
        loading="lazy"
      />
    ))
  }
</section>
