---
type Heading = { depth: number; slug: string; text: string };

type Props = {
  headings: Heading[];
};

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  items.length > 0 && (
    <nav aria-label="Table of contents" class="rounded-xl border border-[var(--color-border)] p-5">
      <p class="mb-3 text-xs font-medium uppercase tracking-wider text-[var(--color-muted)]">
        On this page
      </p>
      <ol class="space-y-2 text-sm">
        {items.map((heading) => (
          <li class:list={[heading.depth === 3 && 'ml-4']}>
            <a
              href={`#${heading.slug}`}
              class="text-[var(--color-muted)] no-underline hover:text-[var(--color-ink)]"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
