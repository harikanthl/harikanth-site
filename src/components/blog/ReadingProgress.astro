---
type Props = {
  accent?: string;
};

const { accent = 'var(--color-accent)' } = Astro.props;
---

<div
  id="reading-progress"
  class="fixed top-0 left-0 z-[60] h-0.5 w-0 origin-left"
  style={`background: ${accent}`}
  aria-hidden="true"
/>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;

    const article = document.querySelector('[data-reading-article]');
    if (!article) return;

    const update = () => {
      const rect = article.getBoundingClientRect();
      const total = article.scrollHeight - window.innerHeight;
      const scrolled = window.scrollY - (article.offsetTop - 80);
      const progress = Math.min(100, Math.max(0, (scrolled / total) * 100));
      bar.style.width = `${progress}%`;
    };

    update();
    window.addEventListener('scroll', update, { passive: true });
  }

  initReadingProgress();
  document.addEventListener('astro:page-load', initReadingProgress);
</script>
