---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { components as mdxComponents } from '../mdx-components';
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import TagPill from '../components/blog/TagPill.astro';
import { formatDate } from '../lib/format';

type Props = {
  note: CollectionEntry<'notes'>;
};

const { note } = Astro.props;
const { Content, headings } = await render(note);
const { title, description, date, tags } = note.data;
---

<BaseLayout title={title} description={description}>
  <article class="page-container py-16">
    <header class="max-w-3xl">
      <p class="text-sm text-[var(--color-muted)]">{formatDate(date)}</p>
      <h1 class="mt-3 text-4xl">{title}</h1>
      <p class="mt-4 text-lg text-[var(--color-muted)]">{description}</p>
      {
        tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <TagPill tag={tag} href={`/notes?tag=${encodeURIComponent(tag)}`} />
            ))}
          </div>
        )
      }
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[1fr_16rem]">
      <div class="prose min-w-0" data-pagefind-body data-pagefind-meta={`title:${title}`}>
        <Content components={mdxComponents} />
      </div>
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
