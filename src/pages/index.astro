---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BioAside from '../components/shell/BioAside.astro';
import PostCard from '../components/blog/PostCard.astro';
import ProjectCoverFlow from '../components/editorial/ProjectCoverFlow.astro';
import { jsonLdPerson } from '../lib/seo';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latestRelease = (await getCollection('projects')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];
const latestDate = latestRelease?.data.date.toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});
---

<BaseLayout jsonLd={jsonLdPerson()} preloadImage="/images/hari-176.jpg">
  <div class="page-container py-10 sm:py-14">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,13rem)_minmax(0,1fr)] lg:gap-16">
      <BioAside />

      <div class="min-w-0">
        {
          latestRelease && (
            <section class="reveal mb-14">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="text-lg font-semibold tracking-tight">Latest release</h2>
                <a
                  href="/projects"
                  class="text-sm text-[var(--color-muted)] no-underline hover:text-[var(--color-ink)]"
                >
                  All projects →
                </a>
              </div>
              <a
                href={`/projects/${latestRelease.id}`}
                class="release-card card-soft group mt-6 flex items-center gap-5 rounded-2xl border border-[var(--color-border)] p-5 no-underline"
              >
                <img
                  src={latestRelease.data.image}
                  alt=""
                  width="64"
                  height="64"
                  loading="eager"
                  class="h-16 w-16 shrink-0 rounded-xl object-cover"
                />
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                    <h3 class="text-xl text-[var(--color-ink)]">{latestRelease.data.title}</h3>
                    <span class="rounded-full bg-[var(--color-accent-soft)] px-2 py-0.5 text-xs font-medium text-[var(--color-accent)]">
                      New · {latestDate}
                    </span>
                  </div>
                  <p class="mt-1 line-clamp-2 text-sm text-[var(--color-muted)]">
                    {latestRelease.data.description}
                  </p>
                </div>
                <span
                  aria-hidden="true"
                  class="release-arrow hidden shrink-0 text-[var(--color-muted)] sm:block"
                >
                  →
                </span>
              </a>
            </section>
          )
        }

        <section class="reveal">
          <div class="flex items-baseline justify-between gap-4">
            <h1 class="text-lg font-semibold tracking-tight">Writing</h1>
            <a
              href="/blog"
              class="text-sm text-[var(--color-muted)] no-underline hover:text-[var(--color-ink)]"
            >
              All posts →
            </a>
          </div>
          <div class="mt-6">
            {posts.map((post, index) => (
              <PostCard post={post} priority={index === 0} />
            ))}
          </div>
        </section>

        {
          projects.length > 0 && (
            <section class="reveal mt-16 border-t border-[var(--color-border)] pt-12">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="text-lg font-semibold tracking-tight">Projects</h2>
                <a
                  href="/projects"
                  class="text-sm text-[var(--color-muted)] no-underline hover:text-[var(--color-ink)]"
                >
                  All projects →
                </a>
              </div>
              <ProjectCoverFlow projects={projects} />
            </section>
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>
