---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDateShort } from '../../lib/format';
import TagPill from '../../components/blog/TagPill.astro';

const tagFilter = Astro.url.searchParams.get('tag');
const allNotes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const notes = tagFilter
  ? allNotes.filter((n) => n.data.tags.includes(tagFilter))
  : allNotes;
---

<BaseLayout
  title="Notes"
  description="Evergreen reference notes on transformers, CUDA, PyTorch, and GPU systems."
>
  <div class="page-container py-16">
    <header class="max-w-2xl">
      <h1 class="text-4xl md:text-5xl">Notes</h1>
      <p class="mt-4 text-lg text-[var(--color-muted)]">
        Dense reference pages designed to be useful long after publication.
      </p>
    </header>

    <ul class="mt-12 divide-y divide-[var(--color-border)]" data-pagefind-body>
      {
        notes.map((note) => (
          <li class="py-6">
            <a href={`/notes/${note.id}`} class="group block no-underline">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h2 class="text-2xl transition-opacity group-hover:opacity-70">
                  {note.data.title}
                </h2>
                <time class="text-sm text-[var(--color-muted)]">
                  {formatDateShort(note.data.date)}
                </time>
              </div>
              <p class="mt-2 text-[var(--color-muted)]">{note.data.description}</p>
              {
                note.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {note.data.tags.map((tag) => (
                      <TagPill tag={tag} href={`/notes?tag=${encodeURIComponent(tag)}`} />
                    ))}
                  </div>
                )
              }
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
