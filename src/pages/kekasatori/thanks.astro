---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kekasatori — Thank you"
  description="Your Kekasatori license key."
  noindex={true}
>
  <div class="page-container py-16 md:py-24">
    <article class="mx-auto max-w-2xl">
      <a href="/projects/kekasatori" class="text-sm text-[var(--color-muted)] no-underline">← Kekasatori</a>
      <h1 class="mt-4 text-4xl">Thank you!</h1>

      <div class="mt-10 space-y-6 text-[var(--color-muted)] leading-relaxed">
        <div id="license-loading">
          <p>Fetching your license key…</p>
        </div>

        <div id="license-ready" hidden>
          <p>
            Your license key is below. It has also been recorded against your purchase email — keep a copy
            somewhere safe.
          </p>
          <div class="mt-4 rounded-lg border border-[var(--color-border,rgba(128,128,128,0.3))] p-4">
            <code id="license-key" class="block break-all text-sm text-[var(--color-ink)]"></code>
            <button
              id="copy-key"
              class="mt-3 rounded-md border border-[var(--color-border,rgba(128,128,128,0.3))] px-3 py-1.5 text-sm"
              type="button"
            >Copy key</button>
          </div>
          <div class="mt-6">
            <h2 class="text-xl text-[var(--color-ink)]">Activate</h2>
            <ol class="mt-2 list-decimal pl-5 space-y-1">
              <li>Open Kekasatori.</li>
              <li>Go to <strong class="text-[var(--color-ink)]">Settings → License</strong>.</li>
              <li>Paste the key and click <strong class="text-[var(--color-ink)]">Activate</strong>.</li>
            </ol>
          </div>
        </div>

        <div id="license-error" hidden>
          <p>
            We couldn't retrieve your key automatically. Don't worry — your purchase went through.
            Email <a href="mailto:harikanth.ai@outlook.com">harikanth.ai@outlook.com</a> from your purchase
            email (or forward your Stripe receipt) and you'll get your key right away.
          </p>
        </div>

        <p class="text-sm">
          Refunds within 14 days, no questions asked — see the
          <a href="/kekasatori/refunds">refund policy</a>.
        </p>
      </div>
    </article>
  </div>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id') ?? '';
  const loading = document.getElementById('license-loading')!;
  const ready = document.getElementById('license-ready')!;
  const error = document.getElementById('license-error')!;
  const keyEl = document.getElementById('license-key')!;

  function show(el: HTMLElement) {
    for (const e of [loading, ready, error]) e.hidden = e !== el;
  }

  async function poll(attempt = 0): Promise<void> {
    if (!sessionId) return show(error);
    try {
      const res = await fetch(`/api/license/claim?session_id=${encodeURIComponent(sessionId)}`);
      if (res.ok) {
        const data = await res.json();
        keyEl.textContent = data.key;
        return show(ready);
      }
    } catch {
      /* retry below */
    }
    // The webhook usually lands within a second or two; poll ~30s total.
    if (attempt < 15) {
      setTimeout(() => poll(attempt + 1), 2000);
    } else {
      show(error);
    }
  }

  document.getElementById('copy-key')?.addEventListener('click', () => {
    navigator.clipboard.writeText(keyEl.textContent ?? '');
    const btn = document.getElementById('copy-key')!;
    btn.textContent = 'Copied ✓';
    setTimeout(() => (btn.textContent = 'Copy key'), 1500);
  });

  poll();
</script>
