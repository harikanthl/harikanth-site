---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Stripe Payment Links (live mode).
const LIFETIME_LINK = 'https://buy.stripe.com/dRmeVc7hUbmcfri1v3cAo01';
const MONTHLY_LINK = 'https://buy.stripe.com/8x26oG9q21LCdjaddLcAo02';
---

<BaseLayout
  title="Buy Kekasatori"
  description="Kekasatori for macOS — $49 lifetime or $4.99/month. 14-day free trial, 14-day refunds."
>
  <div class="page-container py-16 md:py-24">
    <article class="mx-auto max-w-2xl">
      <a href="/projects/kekasatori" class="text-sm text-[var(--color-muted)] no-underline">← Kekasatori</a>
      <h1 class="mt-4 text-4xl">Buy Kekasatori</h1>
      <p class="mt-3 text-[var(--color-muted)]">
        One app, your keys, your Mac. Try everything free for 14 days — then pick whichever shape suits you.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-[var(--color-border,rgba(128,128,128,0.3))] p-6">
          <h2 class="text-xl text-[var(--color-ink)]">Lifetime</h2>
          <p class="mt-1 text-3xl text-[var(--color-ink)]">$49</p>
          <p class="mt-1 text-sm text-[var(--color-muted)]">one-time · all 1.x updates</p>
          <ul class="mt-4 space-y-1 text-sm text-[var(--color-muted)] list-disc pl-5">
            <li>Yours forever, fully offline</li>
            <li>Every update to the current major version</li>
            <li>Use on Macs you own or control</li>
          </ul>
          {LIFETIME_LINK ? (
            <a href={LIFETIME_LINK} class="mt-6 inline-block rounded-md border border-[var(--color-border,rgba(128,128,128,0.3))] px-4 py-2 text-sm no-underline text-[var(--color-ink)]">Buy lifetime — $49</a>
          ) : (
            <p class="mt-6 text-sm text-[var(--color-muted)]">Available shortly.</p>
          )}
        </div>

        <div class="rounded-xl border border-[var(--color-border,rgba(128,128,128,0.3))] p-6">
          <h2 class="text-xl text-[var(--color-ink)]">Monthly</h2>
          <p class="mt-1 text-3xl text-[var(--color-ink)]">$4.99</p>
          <p class="mt-1 text-sm text-[var(--color-muted)]">per month · cancel anytime</p>
          <ul class="mt-4 space-y-1 text-sm text-[var(--color-muted)] list-disc pl-5">
            <li>Same app, no commitment</li>
            <li>Keeps working 7 days past a missed payment</li>
            <li>Switch to lifetime whenever you like</li>
          </ul>
          {MONTHLY_LINK ? (
            <a href={MONTHLY_LINK} class="mt-6 inline-block rounded-md border border-[var(--color-border,rgba(128,128,128,0.3))] px-4 py-2 text-sm no-underline text-[var(--color-ink)]">Subscribe — $4.99/mo</a>
          ) : (
            <p class="mt-6 text-sm text-[var(--color-muted)]">Available shortly.</p>
          )}
        </div>
      </div>

      <div class="mt-10 space-y-3 text-sm text-[var(--color-muted)] leading-relaxed">
        <p>
          Payments are handled by Stripe; your license key appears right after checkout and unlocks the app in
          Settings → License. Kekasatori is bring-your-own-key: AI providers bill you directly at cost, and
          nothing routes through our servers.
        </p>
        <p>
          14-day refunds, no questions asked — see the <a href="/kekasatori/refunds">Terms of Sale &amp;
          Refund Policy</a>, <a href="/kekasatori/terms">Terms of Use</a>, and
          <a href="/kekasatori/privacy">Privacy Policy</a>.
        </p>
      </div>
    </article>
  </div>
</BaseLayout>
