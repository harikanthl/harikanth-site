---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" noindex>
  <div class="page-container flex min-h-[50vh] flex-col items-start justify-center py-20">
    <p class="text-sm text-[var(--color-muted)]">404</p>
    <h1 class="mt-2 text-4xl">Page not found</h1>
    <p class="mt-4 text-[var(--color-muted)]">The page you are looking for does not exist.</p>
    <a href="/" class="btn-primary mt-8 rounded-full px-5 py-2.5 text-sm font-medium">
      Back home
    </a>
  </div>
</BaseLayout>
