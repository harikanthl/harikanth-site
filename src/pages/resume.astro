---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/seo';

const experience = [
  {
    role: 'App Developer',
    company: 'Self-employed',
    period: 'Jan 2025 — Present',
    location: 'San Ramon, CA',
    bullets: [
      'Ideation, mockups, architecture decisions, market-fit research, develop, test, and deploy.',
      'Building AI products including Vireeel and MandiLedger.',
      'Learning PyTorch, CUDA, Triton, and GPU systems.',
    ],
  },
  {
    role: 'Manager',
    company: 'Self-employed (Farm Operations)',
    period: 'Aug 2020 — Nov 2024',
    location: 'India',
    bullets: [
      'Farm operations, sustainable farming practices, and automation.',
      'Project management and on-the-ground agricultural operations.',
    ],
  },
  {
    role: 'Solutions Specialist',
    company: 'Deloitte',
    period: 'Jan 2019 — Jul 2020',
    location: 'Gilbert, AZ',
    bullets: [
      'UAT phase for SAP SD OTC module at a client in Texas.',
      'Cleared pending orders in Ariba order processing for a client in Georgia.',
    ],
  },
  {
    role: 'SAP HANA Associate Trainee',
    company: 'NS2 Serves',
    period: 'Sep 2018 — Nov 2018',
    location: 'Leesburg, VA',
    bullets: [
      'Veteran transition program (Aspen Institute / Franklin Project) for corporate SAP certification.',
    ],
  },
  {
    role: 'iOS Developer',
    company: 'Self-employed',
    period: 'Aug 2016 — Sep 2018',
    location: 'Vancouver, WA · Remote',
    bullets: [
      'Built iOS applications with UIKit and native Apple frameworks.',
    ],
  },
  {
    role: 'Logistics Specialist',
    company: 'US Army',
    period: '2013 — 2016',
    location: 'Fort Lewis, WA',
    bullets: [
      'Trained on GCSS logistics systems; honors graduate at AIT logistics school.',
      'Two years in HR operations.',
    ],
  },
  {
    role: 'SAP Consultant',
    company: 'ISQARE Tech',
    period: 'Jan 2012 — Oct 2013',
    location: 'Greater Houston',
    bullets: [
      'SAP EWM outbound process for a manufacturing client in Illinois.',
      'SAP HR process for a chemical manufacturing client in Tennessee.',
    ],
  },
  {
    role: 'SAP Analyst',
    company: '3SBC',
    period: 'Aug 2011 — Jan 2012',
    location: 'Greater Houston',
    bullets: [
      'SAP SD OTC scenario for a retail client in New Jersey.',
    ],
  },
];

const education = [
  {
    degree: "Master's degree, Electrical and Electronics Engineering",
    school: 'Gannon University',
    period: '2010 — 2011',
  },
  {
    degree: 'BTech, Electrical, Electronics and Communications Engineering',
    school: 'Jawaharlal Nehru Technological University',
    period: '2005 — 2009',
    detail: '3.00 GPA · Electronics Lab & Cricket',
  },
];

const skills = [
  'PyTorch', 'CUDA', 'Triton', 'Python', 'TypeScript',
  'SAP SD', 'SAP EWM', 'SAP HR', 'iOS', 'UIKit',
  'FastAPI', 'Next.js', 'Expo', 'SQLite', 'Cloudflare Workers',
  'System Design', 'Project Management',
];
---

<BaseLayout title="Resume" description="Resume — Harikanth Lingutla, AI/ML Engineer.">
  <div class="page-container py-16 print:py-8" id="resume">
    <div class="flex flex-wrap items-start justify-between gap-6 print:block">
      <header class="flex flex-wrap items-start gap-5 sm:gap-6">
        <div class="media-frame media-frame--portrait print:hidden">
          <img
            src="/images/portfoliopic.jpg"
            alt="Harikanth Lingutla"
            width="112"
            height="112"
            loading="eager"
          />
        </div>
        <div>
          <h1 class="text-3xl font-semibold sm:text-4xl">{SITE.name}</h1>
          <p class="mt-2 text-lg text-[var(--color-muted)]">AI/ML Engineer · Veteran · Builder</p>
          <p class="mt-2 text-sm text-[var(--color-muted)]">
            {SITE.email}
            {' · '}
            <a href={SITE.github} class="underline">GitHub</a>
            {' · '}
            <a href={SITE.linkedin} class="underline">LinkedIn</a>
          </p>
        </div>
      </header>
      <button
        type="button"
        onclick="window.print()"
        class="rounded-full border border-[var(--color-border)] px-5 py-2.5 text-sm print:hidden"
      >
        Download PDF
      </button>
    </div>

    <section class="mt-12 max-w-3xl">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-muted)]">Summary</h2>
      <p class="mt-3 text-lg leading-relaxed">
        MSEE with a career spanning SAP consulting, US Army logistics, iOS development, farm
        management, and AI product building. I ship practical software — from enterprise ERP to
        offline-first farm apps and GPU-accelerated ML. Seeking AI/ML engineering opportunities.
      </p>
    </section>

    <section class="mt-12 max-w-3xl">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-muted)]">Experience</h2>
      <div class="mt-6 space-y-10">
        {
          experience.map((job) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="text-lg font-semibold">{job.role}</h3>
                <span class="text-sm text-[var(--color-muted)]">{job.period}</span>
              </div>
              <p class="text-sm text-[var(--color-muted)]">
                {job.company} · {job.location}
              </p>
              <ul class="mt-3 list-disc space-y-2 pl-5 text-[var(--color-muted)]">
                {job.bullets.map((b) => <li>{b}</li>)}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-12 max-w-3xl">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-muted)]">Education</h2>
      <ul class="mt-4 space-y-4">
        {education.map((e) => (
          <li>
            <strong class="text-[var(--color-ink)]">{e.degree}</strong>
            <p class="text-[var(--color-muted)]">
              {e.school} · {e.period}
              {e.detail ? ` · ${e.detail}` : ''}
            </p>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12 max-w-3xl">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-muted)]">Skills</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {skills.map((s) => (
          <li class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm">{s}</li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  @media print {
    header[class*='sticky'],
    footer,
    button {
      display: none !important;
    }
  }
</style>
